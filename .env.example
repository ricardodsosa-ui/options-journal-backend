# ─── SCHWAB API ───────────────────────────────────────────────────────────────
# From developer.schwab.com → your app's credentials
SCHWAB_CLIENT_ID=your-schwab-app-key-here
SCHWAB_CLIENT_SECRET=your-schwab-app-secret-here

# Your Railway backend URL + /callback
# During setup use: http://localhost:3001/callback
# After Railway deploy use: https://your-app.railway.app/callback
REDIRECT_URI=https://your-app.railway.app/callback

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-hex-string

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-32-byte-hex-string-64-chars

# Generate with: npm run hash-password yourpassword
JOURNAL_PASSWORD_HASH=replace-with-bcrypt-hash-of-your-password

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3001

# Your Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-journal.vercel.app
